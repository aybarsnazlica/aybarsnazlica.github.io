---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Aybars Nazlica | Software Projects',
  description = 'Portfolio site for systems, language, and tooling projects by Aybars Nazlica.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <div class="ambient ambient-left"></div>
      <div class="ambient ambient-right"></div>
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f4efe6;
    --surface: rgba(255, 250, 242, 0.88);
    --surface-strong: #fffaf1;
    --text: #1a2433;
    --muted: #5b6574;
    --accent: #b6542b;
    --accent-strong: #7d2d18;
    --line: rgba(26, 36, 51, 0.12);
    --shadow: 0 24px 80px rgba(35, 29, 24, 0.12);
    --radius-xl: 32px;
    --radius-lg: 24px;
    --radius-md: 18px;
    --font-display: 'Space Grotesk', 'Avenir Next', 'Segoe UI', sans-serif;
    --font-body: 'Space Grotesk', 'Avenir Next', 'Segoe UI', sans-serif;
    --font-mono: 'IBM Plex Mono', 'SFMono-Regular', monospace;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    min-height: 100vh;
    color: var(--text);
    background:
      radial-gradient(circle at top left, rgba(182, 84, 43, 0.22), transparent 28%),
      radial-gradient(circle at 85% 18%, rgba(35, 103, 125, 0.18), transparent 24%),
      linear-gradient(180deg, #f8f3eb 0%, var(--bg) 45%, #efe5d5 100%);
    font-family: var(--font-body);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .page-shell {
    position: relative;
    overflow: hidden;
  }

  .ambient {
    position: fixed;
    inset: auto;
    width: 24rem;
    height: 24rem;
    border-radius: 999px;
    filter: blur(28px);
    opacity: 0.42;
    pointer-events: none;
  }

  .ambient-left {
    top: 6rem;
    left: -10rem;
    background: rgba(182, 84, 43, 0.25);
  }

  .ambient-right {
    right: -8rem;
    top: 24rem;
    background: rgba(35, 103, 125, 0.2);
  }

  .container {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--accent-strong);
    font: 500 0.82rem/1 var(--font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .section-title {
    margin: 0;
    font: 700 clamp(2rem, 5vw, 4.4rem)/0.96 var(--font-display);
    letter-spacing: -0.04em;
  }

  .section-copy {
    margin: 0;
    max-width: 62ch;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.8rem 1.15rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.48);
    font: 500 0.92rem/1 var(--font-body);
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: 3.2rem;
    padding: 0.9rem 1.3rem;
    border-radius: 999px;
    border: 1px solid transparent;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    color: #fff7f0;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-strong) 100%);
    box-shadow: 0 18px 34px rgba(125, 45, 24, 0.2);
  }

  .button-secondary {
    border-color: var(--line);
    background: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 720px) {
    .container {
      width: min(100% - 1.25rem, 1120px);
    }
  }
</style>
