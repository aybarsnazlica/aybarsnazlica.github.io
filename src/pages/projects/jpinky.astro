---
import PinkyPlayground from "../../components/PinkyPlayground";
import Layout from "../../layouts/Layout.astro";
import { findProject } from "../../data/projects";

const project = findProject("jpinky");
const basePath = import.meta.env.BASE_URL;

if (!project) {
    throw new Error("Project not found: jpinky");
}
---

<Layout title="jpinky | Aybars Nazlica" description={project.summary}>
    <main class="project-page container">
        <a class="back-link" href={basePath}>Back to portfolio</a>

        <section class="project-hero">
            <div>
                <h1 class="section-title">{project.title}</h1>
            </div>

            <div class="project-badge">
                <span>{project.year}</span>
                <span>{project.status}</span>
                {
                    project.link && (
                        <a
                            class="project-link"
                            href={project.link}
                            target="_blank"
                            rel="noreferrer"
                            aria-label={`${project.title} on GitHub`}
                        >
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path
                                    d="M12 1.5a10.5 10.5 0 0 0-3.32 20.46c.52.1.7-.22.7-.5v-1.77c-2.87.62-3.48-1.21-3.48-1.21-.47-1.2-1.14-1.52-1.14-1.52-.94-.64.07-.63.07-.63 1.04.08 1.58 1.07 1.58 1.07.93 1.58 2.43 1.12 3.02.85.09-.67.36-1.12.65-1.38-2.29-.26-4.69-1.14-4.69-5.1 0-1.13.4-2.06 1.06-2.79-.11-.26-.46-1.32.1-2.75 0 0 .87-.28 2.86 1.06a9.9 9.9 0 0 1 5.2 0c1.98-1.34 2.85-1.06 2.85-1.06.57 1.43.22 2.49.11 2.75.66.73 1.06 1.66 1.06 2.79 0 3.97-2.41 4.83-4.71 5.08.37.32.7.96.7 1.95v2.89c0 .28.19.61.71.5A10.5 10.5 0 0 0 12 1.5Z"
                                    fill="currentColor"
                                />
                            </svg>
                            <span>GitHub</span>
                        </a>
                    )
                }
            </div>
        </section>

        <section class="project-panels">
            <article class="panel panel-primary">
                <p class="eyebrow">Summary</p>
                <p>{project.summary}</p>
            </article>

            <article class="panel">
                <p class="eyebrow">Stack</p>
                <div class="tag-row">
                    {
                        project.stack.map((item) => (
                            <span class="pill">{item}</span>
                        ))
                    }
                </div>
            </article>
        </section>

        <section class="panel demo-panel">
            <p class="eyebrow">Browser runner</p>
            <PinkyPlayground client:load />
        </section>
    </main>
</Layout>

<style>
    .project-page {
        padding: 2.6rem 0 5rem;
    }

    .back-link {
        display: inline-flex;
        margin-bottom: 1.5rem;
        color: var(--accent-strong);
        font: 500 0.95rem/1 var(--font-mono);
    }

    .project-hero,
    .project-panels {
        display: grid;
        gap: 1.2rem;
    }

    .project-hero,
    .project-panels {
        grid-template-columns: minmax(0, 1.2fr) minmax(240px, 0.8fr);
    }

    .project-hero {
        align-items: end;
        margin-bottom: 1.2rem;
    }

    .project-badge,
    .panel {
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        background: var(--surface);
        box-shadow: var(--shadow);
    }

    .project-badge {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.9rem;
        padding: 1.6rem;
        align-self: stretch;
        font-family: var(--font-mono);
        color: var(--accent-strong);
    }

    .project-link {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        width: fit-content;
        color: inherit;
        text-decoration: none;
    }

    .project-link svg {
        width: 1rem;
        height: 1rem;
        flex: none;
    }

    .panel {
        padding: 1.7rem;
    }

    .panel p,
    .panel li {
        color: var(--muted);
        line-height: 1.75;
    }

    .panel-primary {
        background:
            linear-gradient(
                180deg,
                rgba(255, 248, 241, 0.98),
                rgba(255, 244, 235, 0.9)
            ),
            linear-gradient(
                135deg,
                rgba(182, 84, 43, 0.08),
                rgba(35, 103, 125, 0.08)
            );
    }

    .tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
    }

    ul {
        margin: 0;
        padding-left: 1.1rem;
    }

    li + li {
        margin-top: 0.6rem;
    }

    .demo-panel {
        margin-top: 1.2rem;
    }

    @media (max-width: 900px) {
        .project-hero,
        .project-panels {
            grid-template-columns: 1fr;
        }
    }
</style>
