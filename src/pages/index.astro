---
import ProjectGrid from "../components/ProjectGrid";
import Layout from "../layouts/Layout.astro";
import { featuredProjects } from "../data/projects";
---

<Layout
	title="Aybars Nazlica | Portfolio"
	description="Portfolio site featuring language tooling, systems experiments, and product-minded engineering work."
>
	<main>
		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">Software Engineer</p>
				<h1 class="section-title">
					I build backend systems, data platforms, and machine
					learning infrastructure.
				</h1>
				<p class="hero-text">
					My work spans APIs, data pipelines, orchestration, and
					cloud-native systems. I focus on building reliable platforms
					and internal tools that support data and machine learning
					workflows end to end. This site brings together my personal
					projects and experiments.
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href="#projects"
						>View projects</a
					>
				</div>
			</div>
		</section>

		<section class="projects container" id="projects">
			<div class="section-header">
				<div>
					<p class="eyebrow">Featured work</p>
				</div>
			</div>

			<ProjectGrid client:load projects={featuredProjects} />
		</section>

		<footer class="page-footer container">
			<p>Aybars Nazlica &copy; 2026</p>
		</footer>
	</main>
</Layout>

<style>
	main {
		padding: 2rem 0 5rem;
	}

	.hero {
		display: grid;
		grid-template-columns:
			minmax(1rem, 1fr)
			minmax(0, 1120px)
			minmax(0, 240px)
			minmax(1rem, 1fr);
		padding-top: 2.75rem;
	}

	.hero-copy {
		border: 1px solid var(--line);
		border-radius: var(--radius-xl);
		background: var(--surface);
		box-shadow: var(--shadow);
		backdrop-filter: blur(14px);
	}

	.hero-copy {
		grid-column: 2 / 4;
		padding: clamp(1.6rem, 4vw, 3.4rem);
	}

	.hero-text {
		margin: 1.5rem 0 0;
		max-width: 58ch;
		color: var(--muted);
		font-size: 1.05rem;
		line-height: 1.8;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 2rem;
	}

	.prompt {
		color: var(--accent-strong);
	}

	.muted {
		color: var(--muted);
	}

	.projects {
		padding-top: 4.6rem;
	}

	.page-footer {
		padding-top: 10rem;
		text-align: center;
		color: var(--muted);
		font: 500 0.9rem/1.6 var(--font-mono);
	}

	.page-footer p {
		margin: 0;
	}

	.section-header {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1.6rem;
	}

	@media (max-width: 900px) {
		.hero,
		.section-header {
			grid-template-columns: 1fr;
		}

		.hero-copy {
			grid-column: auto;
			margin: 0 1rem;
		}
	}

	@media (max-width: 720px) {
		main {
			padding-top: 1rem;
		}

		.hero-copy {
			border-radius: 24px;
		}
	}
</style>
