---
import ProjectGrid from "../components/ProjectGrid";
import Layout from "../layouts/Layout.astro";
import { featuredProjects } from "../data/projects";

const basePath = import.meta.env.BASE_URL;
---

<Layout
	title="Aybars Nazlica | Portfolio"
	description="Portfolio site featuring language tooling, systems experiments, and product-minded engineering work."
>
	<main>
		<section class="hero container">
			<div class="hero-copy">
				<p class="eyebrow">Software Engineer</p>
				<h1 class="section-title">
					I build language tools, sharp interfaces, and software with
					an opinion.
				</h1>
				<p class="hero-text">
					This portfolio is a home for projects that balance
					engineering depth with product quality. The current focus is
					jpinky, a small interpreted language built in Java and now
					being shaped for a browser-based playground.
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href="#projects"
						>View projects</a
					>
					<a
						class="button button-secondary"
						href={`${basePath}projects/jpinky`}>See jpinky</a
					>
				</div>
			</div>

			<aside class="hero-panel">
				<div class="hero-panel-frame">
					<p class="eyebrow">Current build</p>
					<div class="terminal-line">
						<span class="prompt">project</span>
						<span>jpinky</span>
					</div>
					<div class="terminal-line muted">
						<span class="prompt">stack</span>
						<span>Java, Gradle, Astro, React</span>
					</div>
					<div class="terminal-line muted">
						<span class="prompt">next</span>
						<span>Browser runner, project writeup, demo UI</span>
					</div>
				</div>
			</aside>
		</section>

		<section class="highlights container">
			<div class="pill">Language implementation</div>
			<div class="pill">Developer tooling</div>
			<div class="pill">Frontend delivery</div>
		</section>

		<section class="projects container" id="projects">
			<div class="section-header">
				<div>
					<p class="eyebrow">Featured work</p>
					<h2 class="section-title">
						Projects with enough substance to deserve their own
						page.
					</h2>
				</div>
				<p class="section-copy">
					The portfolio structure is data-driven, so adding future
					work means appending a project entry and creating a
					dedicated page when the project earns one.
				</p>
			</div>

			<ProjectGrid client:load projects={featuredProjects} />
		</section>
	</main>
</Layout>

<style>
	main {
		padding: 2rem 0 5rem;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.9fr);
		gap: 1.5rem;
		align-items: stretch;
		padding-top: 2.75rem;
	}

	.hero-copy,
	.hero-panel-frame {
		border: 1px solid var(--line);
		border-radius: var(--radius-xl);
		background: var(--surface);
		box-shadow: var(--shadow);
		backdrop-filter: blur(14px);
	}

	.hero-copy {
		padding: clamp(1.6rem, 4vw, 3.4rem);
	}

	.hero-text {
		margin: 1.5rem 0 0;
		max-width: 58ch;
		color: var(--muted);
		font-size: 1.05rem;
		line-height: 1.8;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 2rem;
	}

	.hero-panel {
		display: flex;
	}

	.hero-panel-frame {
		width: 100%;
		padding: 1.5rem;
		background:
			linear-gradient(
				180deg,
				rgba(255, 248, 238, 0.96),
				rgba(249, 241, 232, 0.9)
			),
			linear-gradient(
				135deg,
				rgba(182, 84, 43, 0.06),
				rgba(35, 103, 125, 0.08)
			);
	}

	.terminal-line {
		display: grid;
		grid-template-columns: 5.5rem 1fr;
		gap: 0.9rem;
		padding: 1rem 0;
		border-bottom: 1px solid var(--line);
		font-family: var(--font-mono);
		font-size: 0.94rem;
	}

	.terminal-line:last-child {
		border-bottom: 0;
	}

	.prompt {
		color: var(--accent-strong);
	}

	.muted {
		color: var(--muted);
	}

	.highlights {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		padding: 1.25rem 0 0;
	}

	.projects {
		padding-top: 4.6rem;
	}

	.section-header {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1.6rem;
	}

	@media (max-width: 900px) {
		.hero,
		.section-header {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		main {
			padding-top: 1rem;
		}

		.hero-copy,
		.hero-panel-frame {
			border-radius: 24px;
		}
	}
</style>
