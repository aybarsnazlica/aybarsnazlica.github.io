---
import ProjectGrid from "../components/ProjectGrid";
import Layout from "../layouts/Layout.astro";
import { featuredProjects } from "../data/projects";

const basePath = import.meta.env.BASE_URL;
---

<Layout
	title="Aybars Nazlica | Portfolio"
	description="Portfolio site featuring language tooling, systems experiments, and product-minded engineering work."
>
	<main>
		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">Software Engineer</p>
				<h1 class="section-title">
					I work on backend systems, data platforms, and small tools
					that make technical work easier.
				</h1>
				<p class="hero-text">
					Most of my work is in infrastructure: APIs, pipelines,
					orchestration, and data systems. I currently work across
					backend engineering, data, and machine learning workflows. This site is a
					collection of my personal projects.
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href="#projects"
						>View projects</a
					>
				</div>
			</div>
		</section>

		<section class="projects container" id="projects">
			<div class="section-header">
				<div>
					<p class="eyebrow">Featured work</p>
				</div>
			</div>

			<ProjectGrid client:load projects={featuredProjects} />
		</section>

		<footer class="page-footer container">
			<p>Aybars Nazlica &copy; 2026</p>
		</footer>
	</main>
</Layout>

<style>
	main {
		padding: 2rem 0 5rem;
	}

	.hero {
		display: grid;
		grid-template-columns:
			minmax(1rem, 1fr)
			minmax(0, 1120px)
			minmax(0, 240px)
			minmax(1rem, 1fr);
		padding-top: 2.75rem;
	}

	.hero-copy,
	.hero-panel-frame {
		border: 1px solid var(--line);
		border-radius: var(--radius-xl);
		background: var(--surface);
		box-shadow: var(--shadow);
		backdrop-filter: blur(14px);
	}

	.hero-copy {
		grid-column: 2 / 4;
		padding: clamp(1.6rem, 4vw, 3.4rem);
	}

	.hero-text {
		margin: 1.5rem 0 0;
		max-width: 58ch;
		color: var(--muted);
		font-size: 1.05rem;
		line-height: 1.8;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 2rem;
	}

	.hero-panel {
		display: flex;
	}

	.hero-panel-frame {
		width: 100%;
		padding: 1.5rem;
		background:
			linear-gradient(
				180deg,
				rgba(255, 248, 238, 0.96),
				rgba(249, 241, 232, 0.9)
			),
			linear-gradient(
				135deg,
				rgba(182, 84, 43, 0.06),
				rgba(35, 103, 125, 0.08)
			);
	}

	.terminal-line {
		display: grid;
		grid-template-columns: 5.5rem 1fr;
		gap: 0.9rem;
		padding: 1rem 0;
		border-bottom: 1px solid var(--line);
		font-family: var(--font-mono);
		font-size: 0.94rem;
	}

	.terminal-line:last-child {
		border-bottom: 0;
	}

	.prompt {
		color: var(--accent-strong);
	}

	.muted {
		color: var(--muted);
	}

	.highlights {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		padding: 1.25rem 0 0;
	}

	.projects {
		padding-top: 4.6rem;
	}

	.page-footer {
		padding-top: 10rem;
		text-align: center;
		color: var(--muted);
		font: 500 0.9rem/1.6 var(--font-mono);
	}

	.page-footer p {
		margin: 0;
	}

	.section-header {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1.6rem;
	}

	@media (max-width: 900px) {
		.hero,
		.section-header {
			grid-template-columns: 1fr;
		}

		.hero-copy {
			grid-column: auto;
			margin: 0 1rem;
		}
	}

	@media (max-width: 720px) {
		main {
			padding-top: 1rem;
		}

		.hero-copy,
		.hero-panel-frame {
			border-radius: 24px;
		}
	}
</style>
